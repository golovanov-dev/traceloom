{
    "name": "golovanov/traceloom",
    "description": "A lightweight PHP library for recording structured event timelines grouped by trace ID.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tracing",
        "structured-logging",
        "jsonl",
        "timeline",
        "trace"
    ],
    "autoload": {
        "psr-4": {
            "Golovanov\\Traceloom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Golovanov\\Traceloom\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/eventtrace"
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    }
}
